<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!--
  Minimal Checkstyle config for the Paladin Java SDK.

  Intentionally scoped to a single rule: every method/constructor parameter and local
  variable that is never reassigned must be declared `final`. Formatting is owned by
  Spotless (Google Java Format), so nothing else is configured here to avoid conflicts.
-->
<module name="Checker">
  <property name="severity" value="error"/>

  <module name="TreeWalker">
    <!--
      Require `final` on unmodified locals AND parameters. PARAMETER_DEF extends the
      default (VARIABLE_DEF only) to cover "vars passed in to functions". Genuinely
      reassigned locals/params are not flagged, so no false positives.
    -->
    <module name="FinalLocalVariable">
      <property name="tokens" value="VARIABLE_DEF,PARAMETER_DEF"/>
      <!-- leave enhanced-for loop variables alone (matches common GJF practice) -->
      <property name="validateEnhancedForLoopVariable" value="false"/>
    </module>
  </module>
</module>
